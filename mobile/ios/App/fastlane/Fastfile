default_platform(:ios)

$package_json_path = '../../../../package.json'
$workspace_path = 'App.xcworkspace'
$project_path = '../App.xcodeproj/project.pbxproj'

def env_value(name, fallback = nil)
  value = ENV[name]
  value.nil? || value.empty? ? fallback : value
end

# RC_NUMBER must be a bare integer; anything else (empty, or an API error body that slipped
# through the workflow) is treated as absent so it can never reach the version name or notes.
def rc_ordinal
  n = env_value('RC_NUMBER')
  n.to_s.match?(/\A\d+\z/) ? n : nil
end

# Compact provenance line for the top of the build notes: RC label + version, build time,
# and short commit. On release/* the workflow supplies RC_NUMBER (the Nth store build off the
# branch), so RC builds read "RC 26.7.0-rc.2 ..."; ordinary builds just lead with the version.
def build_meta_line(version)
  rc_number = rc_ordinal
  is_rc = !env_value('IS_RELEASE_CANDIDATE').nil? && !rc_number.nil?
  sha = (env_value('GITHUB_SHA') || '')[0, 7]
  stamp = Time.now.utc.strftime('%Y-%m-%d %H:%M')
  head = is_rc ? "RC #{version}-rc.#{rc_number}" : version
  parts = [head, "#{stamp} UTC"]
  parts << sha unless sha.nil? || sha.empty?
  parts.join(' · ')
end

$variant = env_value('APP_VARIANT', 'mytonwallet').downcase
$variant_config = {
  'mytonwallet' => {
    app_identifier: 'org.mytonwallet.app',
    app_identifier_widget: 'org.mytonwallet.app.AirWidget',
    profile_name: 'MyTonWallet Production profile',
    profile_name_widget: 'MyTonWallet Production profile - Widget',
    scheme: 'MyTonWallet',
    scheme_widget: 'AirWidgetExtension',
    plist_path: '../../App/App/Resources/MyTonWallet/Info.plist',
    testflight_group: 'MTW external group',
  },
  'gram' => {
    app_identifier: 'io.gramwallet.app',
    app_identifier_widget: 'io.gramwallet.app.widget',
    profile_name: 'Gram Wallet Production profile',
    profile_name_widget: 'Gram Wallet Production profile - Widget',
    scheme: 'GramWallet',
    scheme_widget: 'GramWalletWidgetExtension',
    plist_path: '../../App/App/Resources/GramWallet/Info.plist',
    testflight_group: 'Gram Wallet external group',
  },
}

raise "Unknown APP_VARIANT: #{$variant}" unless $variant_config.key?($variant)

$config = $variant_config[$variant]
$plist_path = env_value('IOS_PLIST_PATH', $config[:plist_path])

$team_id = env_value('IOS_TEAM_ID', CredentialsManager::AppfileConfig.try_fetch_value(:team_id))
$app_identifier = env_value('IOS_APP_IDENTIFIER', $config[:app_identifier])
$profile_name = env_value('IOS_PROFILE_NAME', $config[:profile_name])
$scheme = env_value('IOS_SCHEME', $config[:scheme])
$app_identifier_widget = env_value('IOS_APP_IDENTIFIER_WIDGET', $config[:app_identifier_widget])
$profile_name_widget = env_value('IOS_PROFILE_NAME_WIDGET', $config[:profile_name_widget])
$scheme_widget = env_value('IOS_WIDGET_SCHEME', $config[:scheme_widget])
$testflight_group = env_value('IOS_TESTFLIGHT_GROUP', $config[:testflight_group])
$external_beta_enabled = env_value('IOS_EXTERNAL_BETA_ENABLED', 'false') == 'true'
$metadata_path = env_value('IOS_METADATA_PATH')
$asc_key_id = env_value('APP_STORE_CONNECT_KEY_ID', 'TL49GJ73DP')
$asc_issuer_id = env_value('APP_STORE_CONNECT_ISSUER_ID', '519080b4-bc5f-4d06-a889-a69254108348')
$asc_key_path = env_value('APP_STORE_CONNECT_KEY_PATH', './AuthKey.p8')

puts "$variant: #{$variant}"
puts "$app_identifier: #{$app_identifier}"
puts "$profile_name: #{$profile_name}"
puts "$scheme: #{$scheme}"
puts "$app_identifier_widget: #{$app_identifier_widget}"
puts "$profile_name_widget: #{$profile_name_widget}"
puts "$scheme_widget: #{$scheme_widget}"
puts "$testflight_group: #{$testflight_group}"
puts "$external_beta_enabled: #{$external_beta_enabled}"

$project_data = nil
$plist_data = nil

def read_files
  $project_data = File.read($project_path)
  $plist_data = File.read($plist_path)
end

def restore_files
  File.write($project_path, $project_data)
  File.write($plist_path, $plist_data)
end

def update_version_and_build_number
  version = JSON.parse(File.read($package_json_path))["version"]
  # Build number = GitHub Actions run number plus a fixed offset. GITHUB_RUN_NUMBER is a
  # per-workflow counter that only ever increases and is never reused (re-runs keep their
  # number), so the build number stays strictly monotonic. App Store Connect rejects any
  # upload whose build number is not higher than the highest already uploaded for the app
  # ACROSS marketing versions, so the number must increase globally, not reset per version.
  # The offset lifts the counter above build numbers minted by the previous App Store
  # Connect-lookup scheme. No network call and no per-version scoping left to get wrong.
  build_offset = 3300
  run_number = env_value('GITHUB_RUN_NUMBER')
  UI.user_error!('GITHUB_RUN_NUMBER is not set — the build number can only be derived in CI') if run_number.nil?
  build_number = run_number.to_i + build_offset
  UI.message("iOS build number: GITHUB_RUN_NUMBER(#{run_number}) + #{build_offset} = #{build_number}")

  increment_version_number(version_number: version)
  increment_build_number(skip_info_plist: true, build_number: build_number)

  return version, build_number
end

platform :ios do
  desc "Push a new beta build to TestFlight"

  before_all do |lane|
    read_files

    app_store_connect_api_key(
      key_id: $asc_key_id,
      issuer_id: $asc_issuer_id,
      key_filepath: $asc_key_path,
      duration: 1200,
      in_house: false
    )

    update_code_signing_settings(
      path: "App.xcodeproj",
      use_automatic_signing: false,
      profile_name: $profile_name,
      sdk: "iphoneos*",
      team_id: $team_id,
      targets: [$scheme],
      code_sign_identity: "iPhone Distribution"
    )

    update_code_signing_settings(
      path: "App.xcodeproj",
      use_automatic_signing: false,
      profile_name: $profile_name_widget,
      sdk: "iphoneos*",
      team_id: $team_id,
      targets: [$scheme_widget],
      code_sign_identity: "iPhone Distribution"
    )
  end

  lane :beta do
    version, _build_number = update_version_and_build_number

    build_app(
      workspace: $workspace_path,
      scheme: $scheme,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          $app_identifier => $profile_name,
          $app_identifier_widget => $profile_name_widget,
        }
      },
      xcargs: "-skipMacroValidation",
    )

    changelog_from_git_commits(merge_commit_filtering: "exclude_merges", commits_count: 3)

    upload_params = {
      app_identifier: $app_identifier,
      distribute_external: $external_beta_enabled,
      groups: $external_beta_enabled ? $testflight_group : nil,
      beta_app_description: "Bug fixes and performance improvements",
    }

    # Prepend the compact provenance line to the "What to Test" notes so a tester can pin down
    # the exact build (RC ordinal, build time, commit); the notes are the per-build field a
    # TestFlight tester sees. Applies to every build; RC builds lead with the RC label.
    base_notes = lane_context[SharedValues::FL_CHANGELOG] || ""
    upload_params[:changelog] = "#{build_meta_line(version)}\n\n#{base_notes}"

    upload_to_testflight(upload_params)
  end

  lane :release do
    version, build_number = update_version_and_build_number

    changelog_path = "../../../../changelogs/" + version + ".txt"
    if !File.exist?(changelog_path)
      raise "There is no changelog for version " + version
    end

    changelog = File.read(changelog_path)

    build_app(
      workspace: $workspace_path,
      scheme: $scheme,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          $app_identifier => $profile_name,
          $app_identifier_widget => $profile_name_widget,
        }
      },
      xcargs: "-skipMacroValidation",
    )

    upload_options = {
      app_identifier: $app_identifier,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: true,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      force: true,
      release_notes: {
        "default" => changelog,
        "en-US" => changelog,
      }
    }
    upload_options[:metadata_path] = $metadata_path if $metadata_path
    upload_to_app_store(upload_options)
  end

  after_all do |lane|
    restore_files
  end

  error do |lane, exception|
    restore_files
  end

end
