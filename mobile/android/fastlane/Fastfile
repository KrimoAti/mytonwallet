default_platform(:android)

def env_value(name, fallback = nil)
  value = ENV[name]
  value.nil? || value.empty? ? fallback : value
end

# RC_NUMBER must be a bare integer; anything else (empty, or an API error body that slipped
# through the workflow) is treated as absent so it can never reach the version name or notes.
def rc_ordinal
  n = env_value('RC_NUMBER')
  n.to_s.match?(/\A\d+\z/) ? n : nil
end

# Compact provenance line for the top of the build notes: RC label + version, build time,
# and short commit. On release/* the workflow supplies RC_NUMBER (the Nth store build off the
# branch), so RC builds read "RC 26.7.0-rc.2 ..."; ordinary builds just lead with the version.
def build_meta_line(version)
  rc_number = rc_ordinal
  is_rc = !env_value('IS_RELEASE_CANDIDATE').nil? && !rc_number.nil?
  sha = (env_value('GITHUB_SHA') || '')[0, 7]
  stamp = Time.now.utc.strftime('%Y-%m-%d %H:%M')
  head = is_rc ? "RC #{version}-rc.#{rc_number}" : version
  parts = [head, "#{stamp} UTC"]
  parts << sha unless sha.nil? || sha.empty?
  parts.join(' · ')
end

$variant = env_value('APP_VARIANT', 'mytonwallet').downcase
$variant_config = {
  'mytonwallet' => {
    package_name: 'org.mytonwallet.app',
    firebase_app_id: '1:155616896352:android:2d448728d65b6d277eaa05',
    beta_gradle_task: 'assembleMytonwalletBetaRelease',
    release_gradle_task: 'bundleMytonwalletProdRelease',
    direct_gradle_task: 'assembleMytonwalletProdRelease',
  },
  'gram' => {
    package_name: 'io.gramwallet.app',
    firebase_app_id: '1:155616896352:android:539fe0c1f3fc36fa7eaa05',
    beta_gradle_task: 'assembleGramBetaRelease',
    release_gradle_task: 'bundleGramProdRelease',
    direct_gradle_task: 'assembleGramProdRelease',
  },
}

raise "Unknown APP_VARIANT: #{$variant}" unless $variant_config.key?($variant)

$config = $variant_config[$variant]
$package_name = env_value('ANDROID_PACKAGE_NAME', $config[:package_name])
$firebase_app_id = env_value('ANDROID_FIREBASE_APP_ID', $config[:firebase_app_id])
$firebase_groups = env_value('ANDROID_FIREBASE_GROUPS', 'developers,qa')
$play_json_key_file = env_value('ANDROID_PLAY_JSON_KEY_FILE', './api-key.json')
$firebase_service_credentials_file = env_value('ANDROID_FIREBASE_SERVICE_CREDENTIALS_FILE', './firebase-service-account.json')
$beta_gradle_task = env_value('ANDROID_BETA_GRADLE_TASK', $config[:beta_gradle_task])
$release_gradle_task = env_value('ANDROID_RELEASE_GRADLE_TASK', $config[:release_gradle_task])
$direct_gradle_task = env_value('ANDROID_DIRECT_GRADLE_TASK', $config[:direct_gradle_task])

puts "$variant: #{$variant}"
puts "$package_name: #{$package_name}"
puts "$firebase_app_id: #{$firebase_app_id}"
puts "$beta_gradle_task: #{$beta_gradle_task}"
puts "$release_gradle_task: #{$release_gradle_task}"
puts "$direct_gradle_task: #{$direct_gradle_task}"

def build_release_notes
  commit_sha = ENV['GITHUB_SHA']
  short_sha = commit_sha&.slice(0, 7)
  commit_subject = `git log -1 --pretty=%s`.strip
  fallback = "#{commit_subject}\n\nCommit: #{short_sha}"

  return fallback if ENV['GH_TOKEN'].nil? || ENV['GH_TOKEN'].empty? || commit_sha.nil?

  pr_number = `gh pr list --search "#{commit_sha}" --state merged --json number --jq '.[0].number // empty'`.strip
  return fallback if pr_number.empty?

  pr_json = `gh pr view #{pr_number} --json title,body`
  return fallback if pr_json.nil? || pr_json.empty?

  require 'json'
  pr = JSON.parse(pr_json) rescue nil
  return fallback if pr.nil?

  "#{pr['title']} (##{pr_number})\n\n#{pr['body']}\n\nCommit: #{short_sha}"
rescue StandardError
  "#{`git log -1 --pretty=%s`.strip}\n\nCommit: #{ENV['GITHUB_SHA']&.slice(0, 7)}"
end

def play_track_version_code(track)
  version_codes = google_play_track_version_codes(
    package_name: $package_name,
    track: track,
    json_key: $play_json_key_file,
  )

  version_codes[0] || 0
rescue StandardError
  0
end

def firebase_beta_build_number
  latest_release = firebase_app_distribution_get_latest_release(
    app: $firebase_app_id,
    service_credentials_file: $firebase_service_credentials_file,
  )

  latest_release ? latest_release[:buildVersion].to_i : 0
rescue StandardError
  0
end

def signing_properties
  {
    "android.injected.signing.store.file" => $keystore_path,
    "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
    "android.injected.signing.key.alias" => "key0",
    "android.injected.signing.key.password" => ENV["ANDROID_KEYSTORE_PASSWORD"]
  }
end

def write_apk_output_path
  output_path_file = ENV['ANDROID_APK_OUTPUT_PATH_FILE']
  return if output_path_file.nil? || output_path_file.empty?

  output_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]
  return if output_path.nil? || output_path.empty?

  File.write(output_path_file, output_path)
end

def update_version_and_build_number
  play_beta_build_number = play_track_version_code("closed-beta")
  play_production_build_number = play_track_version_code("production")
  firebase_build_number = firebase_beta_build_number

  build_number = [play_beta_build_number, play_production_build_number, firebase_build_number].max + 1
  version = JSON.parse(File.read("../../../package.json"))["version"]

  # RC builds carry the -rc.N ordinal in the version name so they stand out in the Firebase
  # list among the daily *.beta builds (the beta flavor still appends its own .beta suffix).
  rc_number = rc_ordinal
  version_name = (env_value('IS_RELEASE_CANDIDATE').nil? || rc_number.nil?) ? version : "#{version}-rc.#{rc_number}"
  android_set_version_name(version_name: version_name)
  android_set_version_code(version_code: build_number)
end

platform :android do
  desc "Deploy a new Beta Build to the Google Play"

  $gradle_data = nil

  before_all do |lane|
    $gradle_data = File.read("../app/build.gradle")
  end

  $keystore_path = Dir.pwd + "/../android.keystore"

  lane :beta do
    update_version_and_build_number

    gradle(
      task: $beta_gradle_task,
      properties: signing_properties
    )

    release_notes = build_release_notes

    # Prepend the compact provenance line to the Firebase notes so a tester can pin down the
    # exact build (RC ordinal, build time, commit). Applies to every build; RC builds lead
    # with the RC label. The group stays developers,qa (no separate RC group).
    version = JSON.parse(File.read("../../../package.json"))["version"]
    release_notes = "#{build_meta_line(version)}\n\n#{release_notes}"

    firebase_app_distribution(
      app: $firebase_app_id,
      android_artifact_type: "APK",
      android_artifact_path: lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH],
      service_credentials_file: $firebase_service_credentials_file,
      release_notes: release_notes,
      groups: $firebase_groups
    )
  end

  desc "Release a new version to the Google Play"
  lane :release do
    update_version_and_build_number

    gradle(task: "clean")
    gradle(
      task: $release_gradle_task,
      properties: signing_properties
    )

    upload_to_play_store(
      package_name: $package_name,
      json_key: $play_json_key_file,
      track: "production",
      skip_upload_apk: true,
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
    )
  end

  lane :direct do
    update_version_and_build_number

    gradle(
      task: $direct_gradle_task,
      properties: signing_properties
    )

    write_apk_output_path
  end

  after_all do |lane|
    File.write("../app/build.gradle", $gradle_data)
  end

  error do |lane, exception|
    File.write("../app/build.gradle", $gradle_data)
  end
end
